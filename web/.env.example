# ── NextAuth ──────────────────────────────────────────────────────────────
# Genera un secreto con:  openssl rand -base64 32
AUTH_SECRET=

# URL pública de la app (Auth0 la usa como callback base).
NEXTAUTH_URL=http://localhost:3000

# ── Auth0 (Regular Web App) ────────────────────────────────────────────────
# App tipo "Regular Web Application" en el dashboard de Auth0 (confidencial, con secret).
# Callback URL a registrar en Auth0:  {NEXTAUTH_URL}/api/auth/callback/auth0
# Logout URL a registrar:             {NEXTAUTH_URL}
AUTH0_ISSUER=https://TU_DOMINIO.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=

# Identifier de la API en Auth0. OBLIGATORIO: sin audience el access token es opaco.
AUTH0_AUDIENCE=https://api.unipark.edu.sv

# ── Variables públicas (logout federado en el cliente) ──────────────────────
NEXT_PUBLIC_AUTH0_ISSUER=https://TU_DOMINIO.us.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=
